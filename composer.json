{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-soap": "*",
        "laravel/framework": "^13.0",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^3.7",
        "masmerise/livewire-toaster": "^2.10",
        "ryangjchandler/laravel-cloudflare-turnstile": "^3.0",
        "spatie/laravel-permission": "^7.3"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.24",
        "fruitcake/laravel-debugbar": "^4.2",
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.29",
        "laravel/sail": "^1.56",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "nunomaduro/phpinsights": "^2.14",
        "pestphp/pest": "^4.4",
        "phpmd/phpmd": "@stable",
        "phpunit/phpunit": "^12.5.16",
        "spatie/laravel-ignition": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modulos\\": "modulos/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
